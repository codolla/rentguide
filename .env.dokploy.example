# Paste these into the Dokploy Compose service Environment tab.
# Generate APP_KEY with: openssl rand -base64 32
APP_KEY=base64:REPLACE_WITH_32_BYTE_BASE64_KEY
APP_URL=https://rentguide.example.com
APP_HOST=rentguide.example.com
DB_PASSWORD=REPLACE_WITH_A_LONG_RANDOM_PASSWORD
DB_ROOT_PASSWORD=REPLACE_WITH_ANOTHER_LONG_RANDOM_PASSWORD

